/target
/android/.gradle
/android/build
/android/local.properties
/android/app/build
__pycache__/
*.pyc
# Docs pages generated by scripts/build-docs.py in the Pages workflow.
# Only docs/index.html, docs/assets/sample.html, and docs/android-privacy.html
# are checked in (they remain tracked; gitignore only hides untracked files).
docs/adr/*.html
docs/custom-css.html
docs/faux-browser-window.html
docs/file-manager-integration.html
docs/maintaining.html
docs/usage.html
docs/release-notes/*.html
docs/things-tried/*.html

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/
.beads/.local_version
.beads/backup/
.beads/export-state.json
# Local Dolt database + backup stores (sync via refs/dolt/data, not git files)
.beads/embeddeddolt/

# Local Beads runtime artifacts
.beads/interactions.jsonl
.beads/last-touched
